{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AWS": {
    "Region": "ap-south-1",
    "AccountId": "123456789012",
    "Profile": "default"
  },
  "Cognito": {
    "Region": "ap-south-1",
    "UserPoolId": "ap-south-1_YourPoolId",
    "AppClientId": "your-app-client-id"
  },

  // appsettings.json carries local dev placeholder values only. 
  // In production, Parameter Store and Secrets Manager values load 
  // after appsettings.json and override these keys entirely. The 
  // local values are never deployed.
  "OrdersDatabase": {
    "Host": "localhost",
    "Port": 5432,
    "Database": "orders_dev",
    "Username": "dev_user",
    "Password": "dev_password_only_for_local"
  },
  "Orders": {
    "QueueUrl": "https://sqs.ap-south-1.amazonaws.com/123456789012/acn-orders-dev",
    "FeatureNewCheckout": false
  },
  "Network": {
    "VpcId": "vpc-local-dev-placeholder",
    "PrivateSubnetIds": "subnet-local-placeholder-a,subnet-local-placeholder-b",
    "ServiceSecurityGroupId": "sg-local-dev-placeholder"
  },
  "ApiGateway": {
    "BaseUrl": "https://YOUR_API_ID.execute-api.ap-south-1.amazonaws.com/dev"
  },
  "S3": {
    "OrdersBucket": "acn-orders-files-dev",
    "BucketRegion": "ap-south-1"
  },
  "AppPrefix": "acn-dev",
  "AllowedHosts": "*"
}
